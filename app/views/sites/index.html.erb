<div class="min-h-screen bg-gradient-to-br from-gray-900 via-gray-700 to-gray-100 p-1">
  <div class="max-w-4xl mx-auto">
    <div class="mb-12">
      <h1 class="text-5xl font-bold text-white mb-2">Quartz</h1>
      <p class="text-indigo-100">Manage and monitor your sites</p>
    </div>

    <%= link_to "New Site", new_site_path, class: "inline-block px-6 py-3 bg-white text-indigo-600 font-bold rounded-lg shadow-lg hover:shadow-xl hover:scale-105 transition-all mb-8" %>

    <div id="sites" class="space-y-4">
      <% if @sites.any? %>
        <% @sites.each do |site| %>
          <div class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition-shadow bg-linear-120 from-gray-900 from-25% to-gray-300">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <div class="">
                
                <div class="flex items-center gap-2 mb-2">
                  <h3 class="text-xl font-bold text-gray-900">
                    <%= link_to site.name, site.url, target: "_blank", class: "text-white hover:text-indigo-800 hover:underline" %>
                  </h3>
                  <% if device_for_site(site) == true %>
                    <span class="h-3 w-3 rounded-full bg-linear-45 from-green-900 to-green-400">

                    </span>
                  <% else %>
                    <span class="h-3 w-3 rounded-full bg-linear-45 from-red-900 to-red-400">

                    </span>
                  <%end%>
                </div>
                <p class="text-gray-200 text-sm break-all"><%= site.url %></p>
                <div class="flex gap-4 mt-3 text-sm">
                  <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-800">
                    <%= reachable(site) %>
                  </span>
                  
                </div>
              </div>
              <div class="flex gap-2">
                <%= link_to "Edit", site_path(site.id), class: "px-4 py-2 bg-indigo-600 text-white rounded-lg font-semibold hover:bg-indigo-700 transition-colors" %>
                <%= link_to "Delete", site_path(site.id), method: :delete, data: { confirm: "Are you sure?" }, class: "px-4 py-2 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700 transition-colors" %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="bg-white rounded-lg shadow-lg p-12 text-center">
          <p class="text-gray-600 text-lg mb-4">No sites yet</p>
          <%= link_to "Create your first site", new_site_path, class: "text-indigo-600 font-semibold hover:text-indigo-800" %>
        </div>
      <% end %>
    </div>
  </div>
</div>