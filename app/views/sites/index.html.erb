<div class="min-h-screen bg-gradient-to-br from-gray-900 via-gray-800 to-gray-950 p-8">
  <div class="max-w-4xl mx-auto">
    <div class="mb-12">
      <h1 class="text-5xl font-bold text-white mb-2">Quartz</h1>
      <p class="text-gray-400">Manage and monitor your sites</p>
    </div>

    <%= link_to "New Site", new_site_path, class: "inline-block px-6 py-3 bg-gray-700 text-white font-semibold rounded-lg shadow-lg hover:bg-gray-600 hover:shadow-xl transition-all mb-8" %>

    <div id="sites" class="space-y-4">
      <% if @sites.any? %>
        <% @sites.each do |site| %>
          <div class="bg-gray-800 rounded-lg shadow-lg p-6 hover:shadow-xl transition-shadow border border-gray-700">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-3">
                  <h3 class="text-xl font-bold text-white">
                    <%= link_to site.name, site.url, target: "_blank", class: "text-gray-300 hover:text-white hover:underline" %>
                  </h3>
                  <% if site.level_id != nil %>
                    <% if device_for_site(site) == true %>
                      <span title="level.io Status" class="h-3 w-3 rounded-full bg-green-500"></span>
                    <% else %>
                      <span title="level.io Status" class="h-3 w-3 rounded-full bg-red-500"></span>
                    <%end%>
                  <% end %>
                </div>
                <p class="text-gray-400 text-sm break-all mb-3"><%= site.url %></p>
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-gray-700 text-gray-300 text-sm">
                    <% if reachable(site)["ok"] == true %>
                      <span class="h-2 w-2 rounded-full bg-green-500"></span>
                      Reachable
                    <% else %>
                      <span class="h-2 w-2 rounded-full bg-red-500"></span>
                      Unreachable
                    <% end %>
                  </span>
                </div>
              </div>
              <div class="flex gap-2">
                <%= link_to "Edit", edit_site_path(site.id), class: "px-4 py-2 bg-gray-700 text-white rounded-lg font-semibold hover:bg-gray-600 transition-colors" %>
                <%= link_to "Delete", site_path(site.id), method: :delete, data: { confirm: "Are you sure?" }, class: "px-4 py-2 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700 transition-colors" %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="bg-gray-800 rounded-lg shadow-lg p-12 text-center border border-gray-700">
          <p class="text-gray-400 text-lg mb-4">No sites yet</p>
          <%= link_to "Create your first site", new_site_path, class: "text-gray-300 font-semibold hover:text-white" %>
        </div>
      <% end %>
    </div>
  </div>
</div>