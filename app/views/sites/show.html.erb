<div class="min-h-screen bg-gradient-to-br from-gray-900 via-gray-800 to-gray-950 p-8">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-4xl font-bold text-white mb-8">Site <span class="text-gray-400"><%= @site.id %></span></h1>

    <div class="bg-gray-800 rounded-lg shadow-lg p-6 border border-gray-700 mb-6">
      <p class="text-gray-400 mb-2">Name: <span class="text-white"><%= @site.name %></span></p>
      <p class="text-gray-400">URL: <span class="text-white break-all"><%= @site.url %></span></p>
    </div>

    <div class="flex gap-2">
      <%= link_to "Edit", edit_site_path(@site), class: "px-4 py-2 bg-gray-700 text-white rounded-lg font-semibold hover:bg-gray-600 transition-colors" %>
      <%= link_to "Delete", @site, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "px-4 py-2 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700 transition-colors" %>
      <%= link_to "Back", sites_path, class: "px-4 py-2 bg-gray-700 text-white rounded-lg font-semibold hover:bg-gray-600 transition-colors" %>
    </div>
  </div>
</div>