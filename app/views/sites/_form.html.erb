<%= form_with model: site do |form| %>
    <% if form.object.errors.any? %>
        <p class="error"> <%= form.object.errors.full_messages.first%> </p>
    <% end %>

    <div>
        <%= form.label :name%>
        <%= form.text_field :name%>
        <%= form.label :url, "URL"%>
        <%= form.url_field :url %>
        <%= form.label :level_id, "Level ID"%>
        <%= form.select(:level_id, LevelClient.new.get_devices.map { |device| [device["hostname"], device["id"]] }) %>


    <div>
        <%= form.submit %>
    </div>
<% end %>